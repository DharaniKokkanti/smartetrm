# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.
# Used by the "Backend: Debug (real SQL Server)" launch config in the
# workspace's launch.json (envFile attribute).
#
# DB_URL is quoted because it contains ';' — VS Code's envFile parser
# handles that fine either way, but `set -a; source .env; set +a` from a
# terminal does NOT: bash treats unquoted ';' as a command separator and
# silently truncates the value at the first one. Keep the quotes.

DB_URL="jdbc:sqlserver://localhost:1433;databaseName=ETRM_DB;encrypt=true;trustServerCertificate=true"
DB_USERNAME=etrm_app
DB_PASSWORD=changeme
JWT_SECRET=dev-only-secret-replace-me-before-any-real-deployment-CHANGE_THIS
CORS_ORIGINS=http://localhost:5173
